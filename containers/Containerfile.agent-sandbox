# lab-agent-sandbox — base image for per-cell agent execution under gVisor.
#
# Runs as a non-root user (agent / uid 10001) with /workspace as cwd.
# Designed to be invoked from `lab.agent.sandbox.Sandbox` with
# `--runtime=runsc --security-opt label=disable --runtime-flag=ignore-cgroups`.
#
# Keep this image small: gVisor cold-start cost scales with image complexity,
# and each cell creates a fresh container.

FROM registry.fedoraproject.org/fedora-minimal:43

# Core agent userland: python3.13, uv (for tool-server installs), ripgrep
# (fs_grep), curl/bash/coreutils (shell_exec), ca-certs (http_fetch).
# Note: coreutils + curl + bash + ca-certificates + shadow-utils are already in
# fedora-minimal:43; only ask for the extras explicitly.
RUN microdnf install -y \
        python3.13 \
        python3-pip \
        ripgrep \
        tar \
        gzip \
    && microdnf clean all \
    && rm -rf /var/cache/dnf /var/cache/yum /var/log/dnf*

# Symlink python3 -> python3.13 for tool-call ergonomics.
RUN ln -sf /usr/bin/python3.13 /usr/local/bin/python3 \
    && ln -sf /usr/bin/python3.13 /usr/local/bin/python

# Install uv via the standalone installer (faster than pip's resolver, used by
# python_eval / pyproject-style tool snippets).
RUN curl -fsSL https://astral.sh/uv/install.sh \
        | env UV_INSTALL_DIR=/usr/local/bin INSTALLER_NO_MODIFY_PATH=1 sh

# MCP client/server + httpx + pydantic for the in-sandbox tool servers
# (`lab.agent.tools.*`). Installed into the 3.13 site-packages explicitly:
# Fedora 43's default `python3` is 3.14, but we want the 3.13 we explicitly
# pinned above. Bootstrap pip into 3.13 via `ensurepip` and install from
# there, so `python -m lab.agent.tools.*` and the deps resolve against the
# same interpreter.
#
# `pydantic-settings`, `ruamel.yaml`, `ollama`, `lancedb`, `pyarrow`,
# `rank-bm25`, and `tenacity` are pulled in for the kb_query tool — which
# loads lab.rag + lab.settings to query a host-mounted KB. They're heavy,
# but the alternative (host-side retrieval bridged in) breaks the per-call
# sandboxed pattern the rest of the tool surface uses.
#
# `redis` is needed for the Phase 8 two-tier Valkey cache (embedding +
# rerank result tiers).
#
# `sentence-transformers` powers the Phase 7 cross-encoder reranker. We do
# NOT pre-pull the reranker weights — the host-mounted HF cache
# (`/data/lab/services/hf-cache`, see sandbox.py:hf_cache_mount) persists
# them across cells so cold-start is paid once.
RUN python3.13 -m ensurepip --upgrade \
    && python3.13 -m pip install --no-cache-dir \
        "mcp>=1.27" \
        "httpx>=0.27" \
        "pydantic>=2.9" \
        "pydantic-settings>=2.5" \
        "ruamel.yaml>=0.18" \
        "ollama>=0.4" \
        "lancedb>=0.13" \
        "pyarrow>=17" \
        "rank-bm25>=0.2.2" \
        "tenacity>=8.5" \
        "redis>=5.1" \
        "sentence-transformers>=3.0" \
    && rm -rf /root/.cache

# Copy the lab subpackages the in-sandbox tools need:
#   * `lab.agent`    — every tool server lives here
#   * `lab.rag`      — vendored kb-builder modules used by kb_query
#   * `lab.settings` — resolves `LAB_KB_ROOT` and other paths
# Nothing else from src/lab is safe to include here (it'd drag in psycopg,
# boto3, mlflow, etc); the host-side `lab.cli` keeps that surface.
COPY src/lab/agent /usr/lib/python3.13/site-packages/lab/agent
COPY src/lab/rag /usr/lib/python3.13/site-packages/lab/rag
COPY src/lab/settings.py /usr/lib/python3.13/site-packages/lab/settings.py
RUN install -m 0644 /dev/null /usr/lib/python3.13/site-packages/lab/__init__.py \
    && find /usr/lib/python3.13/site-packages/lab -name __pycache__ -exec rm -rf {} + \
    && find /usr/lib/python3.13/site-packages/lab -type d -exec chmod 0755 {} + \
    && find /usr/lib/python3.13/site-packages/lab -type f -exec chmod 0644 {} +

# Non-root execution user. uid/gid 10001 keeps us well clear of host users.
RUN groupadd -g 10001 agent \
    && useradd -m -u 10001 -g 10001 -s /bin/bash agent \
    && mkdir -p /workspace \
    && chown agent:agent /workspace

USER agent
WORKDIR /workspace

# Default to a friendly shell; Sandbox.exec overrides with explicit cmd.
CMD ["/bin/bash"]
