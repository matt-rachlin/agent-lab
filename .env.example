# Copy to .env and fill in. The .env is git-ignored.

# Ollama Cloud (required for cloud model access)
OLLAMA_API_KEY=

# Postgres (defaults assume Unix socket; override if needed)
LAB_PG_DSN=postgresql://m@/lab

# Valkey / Redis (default localhost:6379)
LAB_REDIS_URL=redis://localhost:6379/0

# MinIO (defaults match the lab Podman container)
LAB_S3_ENDPOINT=http://localhost:9000
LAB_S3_BUCKET=lab
LAB_S3_ACCESS_KEY=labadmin
LAB_S3_SECRET_KEY=

# MLflow
LAB_MLFLOW_URL=http://localhost:5000

# LiteLLM proxy
LAB_LITELLM_URL=http://localhost:4000
LAB_LITELLM_KEY=

# Lab home (artifacts root)
LAB_HOME=/data/lab

# llama-swap multi-model orchestrator (Phase 19b/19c).
# All ModelPool clients hit this URL by default.
LAB_LLAMA_SWAP_URL=http://localhost:8080

# Phase 19c — CUDA fragmentation mitigation. The expandable_segments
# allocator lets PyTorch grow/shrink its arenas as models load and
# unload, dramatically reducing OOMs during hot-swap. Set globally for
# every lab process; Ollama's systemd unit also needs this — see
# /etc/systemd/system/ollama.service.d/override.conf.
PYTORCH_CUDA_ALLOC_CONF=expandable_segments:True
